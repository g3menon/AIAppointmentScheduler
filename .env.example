# =============================================================================
# AI Appointment Scheduler — example environment (no secrets here)
# =============================================================================
#
# SETUP STEPS (do these in order)
# -------------------------------
# 1) Copy this file to `.env` in the same directory as this repo root:
#      Windows (PowerShell):  Copy-Item .env.example .env
#      macOS/Linux:           cp .env.example .env
# 2) Open `.env` and replace every `YOUR_...` / `changeme` placeholder.
# 3) Never commit `.env` (it must stay gitignored).
# 4) Start with Phase 1–2: keep GOOGLE_MCP_MODE=fake and skip Google/Gemini keys.
# 5) Phase 3+: set GOOGLE_MCP_MODE=real and complete the Google + NLU sections.
# 6) Phase 7+: enable voice flags only after chat tests pass (see Docs/EnvSetup.md).
#
# REQUIRED vs OPTIONAL
# --------------------
# - Always required: non-secret app toggles (see “App runtime”).
# - Required for LLM NLU (Phase 3+): GEMINI_API_KEY (unless you stay rules-only).
# - Required when GOOGLE_MCP_MODE=real: Google auth + calendar/doc IDs + advisor email.
#
# =============================================================================

# -----------------------------------------------------------------------------
# App runtime
# -----------------------------------------------------------------------------
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000
APP_BASE_URL=http://127.0.0.1:8000

# Session / limits (tune per environment)
SESSION_TTL_MINUTES=30
SESSION_RATE_LIMIT_PER_MINUTE=20
TURN_MAX_RETRIES=1
DEFAULT_TIMEZONE=Asia/Kolkata

# User-facing “complete booking” link template; {code} is replaced with booking code.
# Set to your real handoff URL in production.
SECURE_LINK_BASE_URL=https://example.com/complete?ref={code}

# -----------------------------------------------------------------------------
# Chat / Voice feature toggles
# -----------------------------------------------------------------------------
ENABLE_CHAT_API=true
ENABLE_VOICE_API=false
ENABLE_STT=false
ENABLE_TTS=false

# -----------------------------------------------------------------------------
# NLU / LLM (Phase 3+ — structured intent + entities)
# -----------------------------------------------------------------------------
# How to get GEMINI_API_KEY:
#   1) Open https://aistudio.google.com/apikey (Google account).
#   2) Create API key → copy into GEMINI_API_KEY below.
#   3) Restrict key (HTTP referrer / IP) in Google Cloud Console if possible.
#
# REQUIRED for provider-backed NLU when you call Gemini; omit or dummy only if NLU is rules-only.
NLU_PROVIDER=gemini
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
NLU_MODEL=gemini-2.5-flash
NLU_CONFIDENCE_THRESHOLD=0.65
# Ask provider to minimize retention where the product allows it.
NLU_DISABLE_PROVIDER_LOGGING=true

# -----------------------------------------------------------------------------
# Google MCP integration mode
# -----------------------------------------------------------------------------
# fake = no real Google calls (CI / local Phases 1–2). real = live Calendar/Docs/Gmail.
GOOGLE_MCP_MODE=fake

# Optional: Google Cloud project id (helps support/debug when using Google APIs).
GOOGLE_PROJECT_ID=

# Correlation / idempotency (logs and MCP retries)
IDEMPOTENCY_NAMESPACE=booking
LOG_CORRELATION_ID_HEADER=x-correlation-id

# Integration timeouts (milliseconds) — align with Docs/Architecture.md budgets
GOOGLE_CALENDAR_TIMEOUT_MS=10000
GOOGLE_DOCS_TIMEOUT_MS=5000
GOOGLE_GMAIL_TIMEOUT_MS=5000

# -----------------------------------------------------------------------------
# Google authentication (REQUIRED when GOOGLE_MCP_MODE=real)
# -----------------------------------------------------------------------------
# Choose ONE primary method: OAuth user credentials OR service account file.
#
# GOOGLE_AUTH_MODE=oauth  — act as you (user) with Calendar/Docs/Gmail scopes
# GOOGLE_AUTH_MODE=service_account — headless; calendar/doc must be shared with SA email
#
GOOGLE_AUTH_MODE=oauth

# --- Option A: OAuth 2.0 (desktop / web app) ---
# How to obtain (high level):
#   1) Google Cloud Console → APIs & Services → Enable Calendar, Docs, Gmail APIs.
#   2) OAuth consent screen (test users if External).
#   3) Credentials → Create OAuth client ID (Desktop app or Web).
#   4) Run a one-time OAuth flow locally to exchange code for refresh_token
#      (use Google’s oauth2l or a small script; store ONLY the refresh token in .env).
# Scopes typically include (examples):
#   https://www.googleapis.com/auth/calendar
#   https://www.googleapis.com/auth/documents
#   https://www.googleapis.com/auth/gmail.compose
GOOGLE_OAUTH_CLIENT_ID=YOUR_OAUTH_CLIENT_ID.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=YOUR_OAUTH_CLIENT_SECRET
# Long-lived token from OAuth flow (keep secret; rotate if leaked).
GOOGLE_OAUTH_REFRESH_TOKEN=YOUR_OAUTH_REFRESH_TOKEN
# If you use Web client type, set the redirect URI you registered in Cloud Console.
GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:8080/oauth2callback

# --- Option B: Service account JSON file ---
# How to obtain:
#   1) IAM & Admin → Service Accounts → Create key (JSON) → download file.
#   2) Put path below (no quotes). Example Windows: C:\secrets\scheduler-sa.json
#   3) Share target Calendar + Doc with the service account email from the JSON.
#   4) Set GOOGLE_AUTH_MODE=service_account
# For Workspace domain-wide delegation (advanced), you may also need a subject:
GOOGLE_SERVICE_ACCOUNT_FILE=
# GOOGLE_DELEGATED_SUBJECT=user@yourcompany.com

# -----------------------------------------------------------------------------
# Google resource targets (REQUIRED when GOOGLE_MCP_MODE=real)
# -----------------------------------------------------------------------------
# Calendar: often "primary" for the authenticated user; or a shared calendar ID.
GOOGLE_CALENDAR_ID=primary

# Docs: document ID from the URL:
#   https://docs.google.com/document/d/DOCUMENT_ID_HERE/edit
GOOGLE_PREBOOKING_DOC_ID=YOUR_GOOGLE_DOC_ID

# Gmail: drafts are created for this mailbox / advisor (draft-only; never auto-send in design).
ADVISOR_EMAIL_TO=advisor@example.com

# -----------------------------------------------------------------------------
# Logging / observability (Phase 4+)
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_JSON=true
# Must stay true in production per architecture (no raw user text in logs).
LOG_REDACT_USER_TEXT=true
LOG_INCLUDE_STACKTRACE=false
METRICS_ENABLED=true

# -----------------------------------------------------------------------------
# PII policy (non-negotiable — keep these in production)
# -----------------------------------------------------------------------------
PII_GUARD_ENABLED=true
PII_BLOCK_ON_DETECT=true
PII_STORE_RAW_TRANSCRIPT=false
PII_STORE_RAW_AUDIO=false
PII_AUDIT_FAIL_ON_MATCH=true
