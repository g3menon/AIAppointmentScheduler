# AI Appointment Scheduler - Example Environment File
# Copy this file to `.env` and fill all required values.
#
# Steps:
# 1) Copy: cp .env.example .env
# 2) Fill required values (all keys marked REQUIRED).
# 3) Keep `.env` out of git (do not commit secrets).
# 4) Use sandbox/fake mode first, then enable real Google/MCP mode.

# -----------------------------
# App runtime
# -----------------------------
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000
APP_BASE_URL=http://127.0.0.1:8000

# Session and runtime behavior
SESSION_TTL_MINUTES=30
SESSION_RATE_LIMIT_PER_MINUTE=20
TURN_MAX_RETRIES=1
DEFAULT_TIMEZONE=Asia/Kolkata
SECURE_LINK_BASE_URL=https://example.com/complete?ref={code}

# -----------------------------
# Chat/Voice feature toggles
# -----------------------------
ENABLE_CHAT_API=true
ENABLE_VOICE_API=false
ENABLE_STT=false
ENABLE_TTS=false

# -----------------------------
# NLU / LLM
# -----------------------------
# REQUIRED for LLM-based NLU in Phase 3+ (if not using rules-only mode)
NLU_PROVIDER=gemini
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
NLU_MODEL=gemini-2.5-flash
NLU_CONFIDENCE_THRESHOLD=0.65
NLU_DISABLE_PROVIDER_LOGGING=true

# -----------------------------
# Google MCP mode
# -----------------------------
# Use "fake" for CI/local tests, "real" for live integrations
GOOGLE_MCP_MODE=fake

# Correlation and idempotency
IDEMPOTENCY_NAMESPACE=booking
LOG_CORRELATION_ID_HEADER=x-correlation-id

# -----------------------------
# Google OAuth / Service Account
# -----------------------------
# REQUIRED when GOOGLE_MCP_MODE=real
GOOGLE_AUTH_MODE=oauth

# Option A: OAuth user credentials (desktop/web app)
GOOGLE_OAUTH_CLIENT_ID=YOUR_OAUTH_CLIENT_ID
GOOGLE_OAUTH_CLIENT_SECRET=YOUR_OAUTH_CLIENT_SECRET
GOOGLE_OAUTH_REFRESH_TOKEN=YOUR_OAUTH_REFRESH_TOKEN

# Option B: Service account JSON file path
# Example: C:\path\to\service-account.json
GOOGLE_SERVICE_ACCOUNT_FILE=

# Google resource targets
GOOGLE_CALENDAR_ID=primary
GOOGLE_PREBOOKING_DOC_ID=YOUR_GOOGLE_DOC_ID
ADVISOR_EMAIL_TO=advisor@example.com

# -----------------------------
# Logging / observability
# -----------------------------
LOG_LEVEL=INFO
LOG_JSON=true
LOG_REDACT_USER_TEXT=true
LOG_INCLUDE_STACKTRACE=false
METRICS_ENABLED=true

# -----------------------------
# PII policy controls (must remain true in prod)
# -----------------------------
PII_GUARD_ENABLED=true
PII_BLOCK_ON_DETECT=true
PII_STORE_RAW_TRANSCRIPT=false
PII_STORE_RAW_AUDIO=false
PII_AUDIT_FAIL_ON_MATCH=true

