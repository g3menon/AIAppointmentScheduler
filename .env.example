# =============================================================================
# AI Appointment Scheduler — example environment (no secrets here)
# =============================================================================
#
# SETUP STEPS (do these in order)
# -------------------------------
# 1) Copy this file to `.env` in the same directory as this repo root:
#      Windows (PowerShell):  Copy-Item .env.example .env
#      macOS/Linux:           cp .env.example .env
# 2) Open `.env` and replace every `YOUR_...` / `changeme` placeholder.
# 3) Never commit `.env` (it must stay gitignored).
# 4) Phase 1 booking completion calls real Google (Calendar, Docs, Gmail draft). Fill Google auth + resource IDs below.
# 5) NLU (Gemini) remains optional until you wire provider-backed parsing (Phase 3+).
# 6) Phase 7 (voice): enable STT/TTS after chat + Phase 6 tests pass; enable Cloud Speech & TTS APIs on your GCP project.
#
# REQUIRED vs OPTIONAL
# --------------------
# - Always required: non-secret app toggles (see “App runtime”).
# - Required for LLM NLU (Phase 3+): GEMINI_API_KEY (unless you stay rules-only).
# - Required for Phase 1 confirmed bookings: Google auth + GOOGLE_PREBOOKING_DOC_ID + ADVISOR_EMAIL_TO + calendar access.
# - Phase 7 (Google STT/TTS): same GCP project + service account JSON as Calendar (or OAuth user creds if you wire that path).
#   No extra “secret key” file is required if you reuse GOOGLE_SERVICE_ACCOUNT_FILE — only enable APIs + IAM roles (see Phase 7 block).
#
# =============================================================================

# -----------------------------------------------------------------------------
# App runtime
# -----------------------------------------------------------------------------
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000
APP_BASE_URL=http://127.0.0.1:8000

# Session / limits (tune per environment)
SESSION_TTL_MINUTES=30
SESSION_RATE_LIMIT_PER_MINUTE=20
TURN_MAX_RETRIES=1
DEFAULT_TIMEZONE=Asia/Kolkata

# User-facing “complete booking” link template; {code} is replaced with booking code.
# Set to your real handoff URL in production.
SECURE_LINK_BASE_URL=https://example.com/complete?ref={code}

# -----------------------------------------------------------------------------
# Chat / Voice feature toggles
# -----------------------------------------------------------------------------
ENABLE_CHAT_API=true
# Phase 7: set true when the voice HTTP bridge + adapters are implemented and tested.
ENABLE_VOICE_API=false
# Phase 7: enable when Google Cloud Speech-to-Text / Text-to-Speech adapters are wired.
ENABLE_STT=false
ENABLE_TTS=false

# -----------------------------------------------------------------------------
# Phase 7 — Google Cloud Speech-to-Text (STT) & Text-to-Speech (TTS)
# -----------------------------------------------------------------------------
# Prerequisites (do these in Google Cloud Console — no new secrets if you reuse the same SA key):
#   1) Pick your GCP project (same as Calendar/Docs or a dedicated project).
#   2) Enable APIs: “Cloud Speech-to-Text API” and “Cloud Text-to-Speech API”.
#   3) Grant the same service account this app uses for Calendar (see “Google authentication” below) at least:
#        - roles/speech.client          (Speech-to-Text)
#        - roles/cloudtexttospeech.user (Text-to-Speech)
#      Or broader roles (e.g. Editor) in dev only — prefer least privilege in production.
#   4) Auth uses the same resolution as MCP: JSON path (GOOGLE_SERVICE_ACCOUNT_FILE or GOOGLE_APPLICATION_CREDENTIALS),
#      optional inline GOOGLE_SERVICE_ACCOUNT_JSON, or Application Default Credentials — see that section.
#
# Project id (used by some Speech v2 / client initializers). Often matches GOOGLE_PROJECT_ID above.
GOOGLE_CLOUD_PROJECT=
# If empty, Phase 7 code may fall back to GOOGLE_PROJECT_ID — keep one of them set for production voice.

# --- Speech-to-Text (ingest: microphone / uploaded audio → text for the chat orchestrator) ---
# BCP-47 language; en-IN fits IST-focused product copy; use en-US if your users are US-only.
GOOGLE_STT_LANGUAGE_CODE=en-IN
# Region for the Speech API endpoint (examples: global, us, europe-west1). Must match how you call the API in code.
GOOGLE_STT_REGION=global
# Model name depends on API version (v1 vs v2). Examples: latest_long, phone_call, telephony (adjust when implementing).
GOOGLE_STT_MODEL=latest_long
# Audio you send must match encoding below (e.g. LINEAR16 with sample rate for Web Audio / WAV chunks).
GOOGLE_STT_AUDIO_ENCODING=LINEAR16
GOOGLE_STT_SAMPLE_RATE_HZ=16000

# --- Text-to-Speech (egress: assistant text → audio for the browser or client) ---
GOOGLE_TTS_LANGUAGE_CODE=en-IN
# Voice name from Cloud TTS catalog, e.g. en-IN-Wavenet-D, en-IN-Neural2-A (pick in Console → Text-to-Speech → Voices).
GOOGLE_TTS_VOICE_NAME=en-IN-Wavenet-D
# MP3 is convenient for browser playback; LINEAR16/OGG_OPUS are alternatives depending on client support.
GOOGLE_TTS_AUDIO_ENCODING=MP3
# Speaking rate: 1.0 = default; range typically ~0.25–4.0 in Cloud TTS.
GOOGLE_TTS_SPEAKING_RATE=1.0
GOOGLE_TTS_PITCH=0.0

# Voice UX / compliance (align with Docs/Rules.md P6.x — defaults should stay safe)
VOICE_MAX_ASSISTANT_CHARS_PER_UTTERANCE=500
# Keep false in production unless you have an approved retention policy.
VOICE_STORE_RAW_AUDIO=false

# -----------------------------------------------------------------------------
# Phase 5 — Web Chat UI (Node) + HTTP API (FastAPI)
# -----------------------------------------------------------------------------
# Run API:  uvicorn src.api.http.chat_app:app --reload --host 127.0.0.1 --port 8000
# Run UI:   cd web/chat-ui && npm install && npm run dev   (Vite proxies /api → 8000 by default)
# Or set VITE_CHAT_API_URL=http://127.0.0.1:8000 and allow origins below.
# Comma-separated browser origins for CORS (dev defaults include Vite :5173).
CHAT_API_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# -----------------------------------------------------------------------------
# NLU / LLM (Phase 3+ — structured intent + entities)
# -----------------------------------------------------------------------------
# How to get GEMINI_API_KEY:
#   1) Open https://aistudio.google.com/apikey (Google account).
#   2) Create API key → copy into GEMINI_API_KEY below.
#   3) Restrict key (HTTP referrer / IP) in Google Cloud Console if possible.
#
# REQUIRED for provider-backed NLU when you call Gemini; omit or dummy only if NLU is rules-only.
NLU_PROVIDER=gemini
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
NLU_MODEL=gemini-2.5-flash
NLU_CONFIDENCE_THRESHOLD=0.65
# Ask provider to minimize retention where the product allows it.
NLU_DISABLE_PROVIDER_LOGGING=true

# -----------------------------------------------------------------------------
# Google MCP (Phase 1+ — real APIs)
# -----------------------------------------------------------------------------
# Production and local manual runs use real Google APIs via GoogleMcpClient.from_env() in code.
# Automated pytest runs use an in-memory recorder (no credentials) when PYTEST_CURRENT_TEST is set.
#
# When GEMINI_API_KEY is set (and you are not in pytest), confirmed booking can run the trio via Gemini
# automatic function calling (tool names match FastMCP). To always call Google APIs without the LLM:
#   BOOKING_MCP_DRIVER=direct

# Optional: Google Cloud project id (helps support/debug when using Google APIs).
GOOGLE_PROJECT_ID=

# Correlation / idempotency (logs and MCP retries)
IDEMPOTENCY_NAMESPACE=booking
LOG_CORRELATION_ID_HEADER=x-correlation-id

# Integration timeouts (milliseconds) — align with Docs/Architecture.md budgets
GOOGLE_CALENDAR_TIMEOUT_MS=10000
GOOGLE_DOCS_TIMEOUT_MS=5000
GOOGLE_GMAIL_TIMEOUT_MS=5000

# -----------------------------------------------------------------------------
# Google authentication (REQUIRED for manual Phase 1 booking → Google MCP trio)
# -----------------------------------------------------------------------------
# Recommended: service account JSON (headless). Calendar + Docs: share resources with the SA email.
# Gmail drafts: the Gmail API uses userId='me'. With a service account you need Google Workspace
# domain-wide delegation + GOOGLE_DELEGATED_SUBJECT (impersonate that user’s mailbox). Otherwise use OAuth.
#
GOOGLE_AUTH_MODE=service_account

# --- Service account (recommended) ---
# The app resolves credentials in this order (first that succeeds wins):
#   1) GOOGLE_SERVICE_ACCOUNT_JSON — full key JSON as a single-line string (SECRET). For CI/secret managers;
#      local dev usually uses a file path instead.
#   2) GOOGLE_SERVICE_ACCOUNT_FILE — absolute path to the JSON key file (SECRET path). Typical for local dev.
#   3) GOOGLE_APPLICATION_CREDENTIALS — standard Google ADC path to the same JSON file (SECRET path).
#   4) Application Default Credentials — e.g. GCE/GKE workload identity, or
#      `gcloud auth application-default login` (no file env vars set).
#
# 1) Cloud Console → IAM → Service Accounts → Keys → Add JSON key → download.
# 2) For local JSON-on-disk: set GOOGLE_SERVICE_ACCOUNT_FILE (or only GOOGLE_APPLICATION_CREDENTIALS).
GOOGLE_SERVICE_ACCOUNT_FILE=
# Optional: inline key JSON (single line). Do not commit; prefer file path or a secret store in production.
GOOGLE_SERVICE_ACCOUNT_JSON=
# Optional: same as GOOGLE_SERVICE_ACCOUNT_FILE if you follow Google’s ADC convention exclusively.
GOOGLE_APPLICATION_CREDENTIALS=
# Google Workspace only — impersonate a real user so Gmail drafts work (Admin must authorize this SA + scopes).
# Leave empty only if you are not using Gmail via SA (not supported for user mailboxes without delegation).
GOOGLE_DELEGATED_SUBJECT=

# --- OAuth 2.0 (alternative if you are not using Workspace delegation) ---
# GOOGLE_AUTH_MODE=oauth
GOOGLE_OAUTH_CLIENT_ID=YOUR_OAUTH_CLIENT_ID.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=YOUR_OAUTH_CLIENT_SECRET
GOOGLE_OAUTH_REFRESH_TOKEN=YOUR_OAUTH_REFRESH_TOKEN
GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:8080/oauth2callback

# -----------------------------------------------------------------------------
# Google resource targets (REQUIRED for Phase 1 booking → MCP trio)
# -----------------------------------------------------------------------------
# Calendar: ID of a calendar shared with the service account email (or primary when using delegation as that user).
GOOGLE_CALENDAR_ID=primary

# Docs: document ID from the URL:
#   https://docs.google.com/document/d/DOCUMENT_ID_HERE/edit
GOOGLE_PREBOOKING_DOC_ID=YOUR_GOOGLE_DOC_ID

# Gmail: drafts are created for this mailbox / advisor (draft-only; never auto-send in design).
ADVISOR_EMAIL_TO=advisor@example.com

# -----------------------------------------------------------------------------
# Logging / observability (Phase 4+)
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_JSON=true
# Must stay true in production per architecture (no raw user text in logs).
LOG_REDACT_USER_TEXT=true
LOG_INCLUDE_STACKTRACE=false
METRICS_ENABLED=true

# -----------------------------------------------------------------------------
# PII policy (non-negotiable — keep these in production)
# -----------------------------------------------------------------------------
PII_GUARD_ENABLED=true
PII_BLOCK_ON_DETECT=true
PII_STORE_RAW_TRANSCRIPT=false
PII_STORE_RAW_AUDIO=false
PII_AUDIT_FAIL_ON_MATCH=true
