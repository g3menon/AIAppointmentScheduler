# -----------------------------------------------------------------------------
.venv/
venv/
env/
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg
*.egg-info/
.eggs/
dist/
build/
pip-wheel-metadata/

# Type checkers / linters (if added later)
.mypy_cache/
.ruff_cache/
.dmypy.json

